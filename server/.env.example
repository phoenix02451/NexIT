# Local: mongodb://127.0.0.1:27017/itcompany
# Netlify: Site settings → Environment variables — set ONE of these (Atlas SRV recommended):
#   MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/itcompany
#   MONGODB_URI=...  or  DATABASE_URL=...  (same string; aliases supported in server/db.js)
MONGO_URI=mongodb://127.0.0.1:27017/itcompany
PORT=5000
CLIENT_URL=http://localhost:5173

# Auth — use a long random string in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES=7d

# Google Sign-In (same Web client ID as optional VITE_GOOGLE_CLIENT_ID on the client)
GOOGLE_CLIENT_ID=707099185222-bcn90sbtf6te9jke89hjpebqcnd9g7ao.apps.googleusercontent.com

# SMTP — optional; used for contact/career notifications (not required for account sign-up)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=Phoenix040501@outlook.com
SMTP_PASS=dmsgktn040501
SMTP_TO=
SMTP_FROM_NAME=Website Form
