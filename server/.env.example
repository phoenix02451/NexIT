MONGO_URI=mongodb://127.0.0.1:27017/itcompany
PORT=5000
CLIENT_URL=http://localhost:5173

# Auth — set JWT_SECRET to a long random string in production
JWT_SECRET=ITCOMPNAYINFO
JWT_EXPIRES=7d

# Google Sign-In — Web client ID (same value as VITE_GOOGLE_CLIENT_ID on the client)
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Optional: same behavior as PHP PHPMailer (Gmail app password, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=
SMTP_FROM_NAME=Website Form
