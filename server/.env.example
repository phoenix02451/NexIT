# --- Atlas ↔ this app ---
# Use Atlas “Connect → Drivers” mongodb+srv://… string. DB name in the path should match this project (default: itcompany).
# Atlas: Network Access → allow 0.0.0.0/0 (or AWS) for serverless. Database Access → user must have read/write on that DB.
# Password special chars (@ # / ? &) must be URL-encoded inside MONGO_URI. Netlify: same var for Functions scope + redeploy.
# Rare: if Atlas times out only from Netlify, try MONGO_FORCE_IPV4=1 in Netlify env (then redeploy).
#
# Local: mongodb://127.0.0.1:27017/itcompany
# Netlify: MONGO_URI=mongodb+srv://user:URL_ENCODED_PASS@cluster.xxxxx.mongodb.net/itcompany?retryWrites=true&w=majority
#   (aliases: MONGODB_URI, DATABASE_URL)
MONGO_URI=mongodb://127.0.0.1:27017/itcompany
PORT=5000
CLIENT_URL=http://localhost:5173

# Auth — use a long random string in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES=7d

# Google Sign-In (same Web client ID as optional VITE_GOOGLE_CLIENT_ID on the client)
GOOGLE_CLIENT_ID=707099185222-bcn90sbtf6te9jke89hjpebqcnd9g7ao.apps.googleusercontent.com

# SMTP — optional; used for contact/career notifications (not required for account sign-up)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=Phoenix040501@outlook.com
SMTP_PASS=dmsgktn040501
SMTP_TO=
SMTP_FROM_NAME=Website Form
