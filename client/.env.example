# Google Sign-In (OAuth 2.0 Web client ID from Google Cloud Console → APIs & Services → Credentials)
# Optional if server/.env has the same value in GOOGLE_CLIENT_ID: the app also loads it at runtime from /api/auth/config
# (required for Netlify unless you set VITE_GOOGLE_CLIENT_ID in the Netlify build env). Restart Vite after changes.
# VITE_GOOGLE_CLIENT_ID=…apps.googleusercontent.com
